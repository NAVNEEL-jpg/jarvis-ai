# ============================================================
# JARVIS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# DO NOT commit .env to git.

# ----------------------------------------------------------
# Supabase (optional — enables persistent memory)
# Get these from: https://app.supabase.com → Project Settings → API
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------
# Amazon Alexa (controls Echo + ALL Alexa-linked devices)
# e.g., Avita AC, smart bulbs, plugs, fans via Alexa skills
# ALEXA_REGION: amazon.in / amazon.com / amazon.co.uk
# ----------------------------------------------------------
AMAZON_EMAIL=you@gmail.com
AMAZON_PASSWORD=your_amazon_password
ALEXA_REGION=amazon.in

# ----------------------------------------------------------
# Google Home (controls Nest speakers + Google Home devices)
# Use a Google App Password (not your main password)
# Generate at: myaccount.google.com/apppasswords
# ----------------------------------------------------------
GOOGLE_HOME_EMAIL=you@gmail.com
GOOGLE_HOME_PASSWORD=your_google_app_password

# ----------------------------------------------------------
# Home Assistant (optional — heavy hub, not required)
# Only needed if you already run Home Assistant
# ----------------------------------------------------------
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# ----------------------------------------------------------
# Tuya / Smart Life direct local control (optional)
# Only needed if NOT using Home Assistant
# Get device info: tinytuya wizard (pip install tinytuya)
# Format: {"device_alias":{"id":"...","ip":"...","key":"..."}}
# ----------------------------------------------------------
TUYA_DEVICES={}

# ----------------------------------------------------------
# Session identifier (used to tag conversation logs)
# ----------------------------------------------------------
JARVIS_SESSION_ID=default
